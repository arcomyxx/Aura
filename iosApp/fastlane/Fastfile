default_platform(:ios)

platform :ios do
  desc "Build signe + upload vers TestFlight"
  lane :beta do
    # Authentification a App Store Connect via cle API (.p8 decode en fichier par le workflow)
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # Build + signature automatique (cloud signing gere par Apple via la cle API)
    build_app(
      workspace: "iosApp.xcworkspace",
      scheme: "iosApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath", ENV["ASC_KEY_PATH"],
        "-authenticationKeyID", ENV["ASC_KEY_ID"],
        "-authenticationKeyIssuerID", ENV["ASC_ISSUER_ID"],
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        "CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}"
      ].join(" "),
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["APPLE_TEAM_ID"]
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
