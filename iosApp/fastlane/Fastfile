default_platform(:ios)

platform :ios do
  desc "Build signe + upload vers TestFlight"
  lane :beta do
    # Trousseau temporaire propre pour la CI
    setup_ci

    # Authentification a App Store Connect via cle API (.p8 decode en fichier par le workflow)
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # Certificat de DISTRIBUTION (development: false = distribution),
    # installe dans le trousseau temporaire cree par setup_ci.
    cert(
      api_key: api_key,
      development: false,
      keychain_path: ENV["MATCH_KEYCHAIN_NAME"],
      keychain_password: ENV["MATCH_KEYCHAIN_PASSWORD"] || ""
    )

    # Profil APP STORE pour le bundle id (pas besoin d'appareil enregistre)
    sigh(
      api_key: api_key,
      app_identifier: "com.dubois.aura",
      development: false
    )
    profile_name = lane_context[SharedValues::SIGH_NAME]

    # Build + signature MANUELLE de distribution
    build_app(
      workspace: "iosApp.xcworkspace",
      scheme: "iosApp",
      configuration: "Release",
      export_method: "app-store",
      xcargs: [
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        "CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}",
        "CODE_SIGN_STYLE=Manual",
        "PROVISIONING_PROFILE_SPECIFIER=#{profile_name}"
      ].join(" "),
      export_options: {
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "com.dubois.aura" => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
